# PostgreSQL - point at casi-dashboard DB (read-only user recommended)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=casi_dashboard
DB_USER=casi_ai_readonly
DB_PASSWORD=your_password_here

# Paths (use forward slashes on Windows too)
MODEL_SAVE_DIR=./model/saved
DATA_DIR=./data/output

# Training
TRAINING_MONTHS=8
BATCH_SIZE=16
EPOCHS=5
LEARNING_RATE=2e-5
MAX_SEQ_LENGTH=512
CONFIDENCE_THRESHOLD=0.65
VALIDATION_SPLIT=0.1
TEST_SPLIT=0.1

# API server
API_HOST=0.0.0.0
API_PORT=8001
API_SECRET_KEY=change_me_to_a_random_secret

LOG_LEVEL=INFO
